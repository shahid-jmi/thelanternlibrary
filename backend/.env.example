# --- Required ---
MONGO_URI=mongodb://localhost:27017/bookstore
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_random_64_char_hex_string
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-public-bucket-url.example.com

# --- Optional ---
PORT=8000
# Comma-separated list of allowed origins.
# REQUIRED in production — the server refuses to start without it.
# Defaults to http://localhost:5173 in development.
CORS_ORIGIN=http://localhost:5173
# pino log level: fatal | error | warn | info | debug | trace (default: info)
LOG_LEVEL=info
# Set to enable Sentry error tracking. Leave unset to disable.
# SENTRY_DSN=https://xxxxx@xxxx.ingest.sentry.io/xxxx

# Admin accounts are not configured via env vars.
# Create the first super admin with: npm run create-super-admin
# Create subsequent admins via POST /api/v1/admin/admins (requires a super admin token).
