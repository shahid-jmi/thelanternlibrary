{
  "name": "@thelanternlibrary/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The Lantern Library — bookstore API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/scripts/seed.ts",
    "create-super-admin": "tsx src/scripts/createSuperAdmin.ts",
    "migrate-cover-images": "tsx src/scripts/migrateCoverImages.ts",
    "remove-stale-persian-fields": "tsx src/scripts/removeStalePersianFields.ts",
    "rename-cover-image-public-id-to-key": "tsx src/scripts/renameCoverImagePublicIdToKey.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@sentry/node": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^2.2.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.35.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "mongodb-memory-server": "^10.1.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.0.0"
  }
}
